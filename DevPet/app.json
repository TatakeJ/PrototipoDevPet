{
  "expo": {
    "name": "DevPet",
    "slug": "DevPet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/HeadPet.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/HeadPet.png",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F172A"
      }
    },
    "web": {
      "favicon": "./assets/HeadPet.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir acceso a la cámara"
        }
      ],
      "expo-asset"
    ]
  }
}
